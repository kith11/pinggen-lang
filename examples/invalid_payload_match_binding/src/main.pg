import std::{ io }

enum Result {
    Ok(int),
    Err(string),
    Pending,
}

func main() {
    let result = Result::Ok(1);
    match result {
        Result::Ok(value) => {
            io::println("ok");
        }
        Result::Err => {
            io::println("err");
        }
        Result::Pending => {
            io::println("pending");
        }
    }
}
