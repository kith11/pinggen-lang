import model;

func finish(code: int) -> Result {
    if code == 0 {
        return Result::Ok(7);
    }
    return Result::Err("bad");
}

func describe(result: Result) -> string {
    match result {
        Result::Ok(value) => {
            if value > 5 {
                return "ok";
            }
            return "small";
        }
        Result::Err(message) => {
            return message;
        }
        Result::Pending => {
            return "pending";
        }
    }
}
