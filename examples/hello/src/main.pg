import std::{ io }

func classify(value: int) -> string {
    if value % 2 == 0 {
        return "even";
    } else if value > 3 {
        return "large";
    } else {
        return "small";
    }
}

func main() {
    let mut count = 6;
    while count > 0 {
        io::println(classify(count));
        if count <= 2 {
            break;
        }
        count = count - 1;
    }
}
