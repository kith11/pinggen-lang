import std::{ io }

func main() {
    let mut sum = 0;
    for i in 0..6 {
        if i == 1 {
            continue;
        }
        if i == 4 {
            break;
        }
        io::println(i);
        sum = sum + i;
    }
    io::println(sum);

    let start = 5;
    let end = 3;
    for j in start..end {
        io::println(j);
    }
}
