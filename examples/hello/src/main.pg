import std::{ io }

func should_print(value: int) -> bool {
    return value <= 2 || value == 4;
}

func main() {
    let mut count = 4;
    while count > 0 {
        if !should_print(count) {
            count = count - 1;
            continue;
        }
        io::println(count);
        if count <= 2 {
            break;
        }
        count = count - 1;
    }
}
