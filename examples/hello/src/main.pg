import std::{ io }

func is_zero(value: int) -> bool {
    return value == 0;
}

func describe_zero(flag: bool) {
    if flag {
        io::println("value is zero");
    } else {
        io::println("value is not zero");
    }
}

func main() {
    let number = 0;
    let zero = is_zero(number);
    describe_zero(zero);
    if zero != false {
        io::println("pinggen online");
    } else {
        io::println("unexpected branch");
    }
}
