import std::{ io }

func is_even(value: int) -> bool {
    return value % 2 == 0;
}

func main() {
    let mut count = 6;
    while count > 0 {
        if is_even(count) {
            io::println(count);
        }
        if count <= 2 {
            break;
        }
        count = count - 1;
    }
}
