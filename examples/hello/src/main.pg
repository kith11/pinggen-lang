import std::{ io }

func keep_value(value: int) -> bool {
    return value == 3 || value == 1;
}

func main() {
    let mut count = 4;
    while count != 0 {
        count = count - 1;
        if !keep_value(count) && count != 0 {
            continue;
        }
        io::println(count);
        if count == 1 || count == 0 {
            break;
        }
    }
}
