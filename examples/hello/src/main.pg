import std::{ io }

struct Hero {
    hp: int
    alive: bool
    name: string
}

func revive(hero: Hero) -> Hero {
    return Hero { hp: hero.hp + 50, alive: true, name: hero.name };
}

func main() {
    let mut hero = Hero { hp: 10, alive: false, name: "pinggen" };
    hero.hp = 25;
    let upgraded = revive(hero);
    if upgraded.alive {
        io::println(upgraded.name);
        io::println(upgraded.hp);
    }
}
