import std::{ io, fs }

func main() {
    match fs::create_dir("shared-dir") {
        FsWriteResult::Ok => {
            match fs::create_dir("shared-dir") {
                FsWriteResult::Ok => {
                    io::println("exists-ok");
                }
                FsWriteResult::Err(message) => {
                    io::println(message);
                }
            }
        }
        FsWriteResult::Err(message) => {
            io::println(message);
        }
    }
}
